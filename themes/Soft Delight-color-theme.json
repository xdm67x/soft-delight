  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#6B7280"
      }
    },
    {
      "scope": ["keyword", "storage.type", "storage.modifier"],
      "settings": {
        "foreground": "#7C3AED"
      }
    },
    {
      "scope": ["string", "string.quoted", "string.template"],
      "settings": {
        "foreground": "#4338CA"
      }
    },
    {
      "scope": ["constant.numeric", "constant.language"],
      "settings": {
        "foreground": "#D97706"
      }
    },
    {
      "scope": ["entity.name.function", "support.function"],
      "settings": {
        "foreground": "#0369A1"
      }
    },
    {
      "scope": ["entity.name.type", "support.type"],
      "settings": {
        "foreground": "#059669"
      }
    },
    {
      "scope": ["variable", "identifier"],
      "settings": {
        "foreground": "#2D3436"
      }
    },
    {
      "scope": ["entity.name.class", "support.class"],
      "settings": {
        "foreground": "#81B29A"
      }
    },
    {
      "scope": ["punctuation", "meta.brace", "meta.delimiter"],
      "settings": {
        "foreground": "#4B5563"
      }
    },
    {
      "scope": ["operator", "keyword.operator"],
      "settings": {
        "foreground": "#BE185D"
      }
    },
    {
      "scope": ["tag", "entity.name.tag"],
      "settings": {
        "foreground": "#7EB5D6"
      }
    },
    {
      "scope": ["attribute", "entity.other.attribute-name"],
      "settings": {
        "foreground": "#B45309"
      }
    },
    {
      "scope": ["invalid", "error"],
      "settings": {
        "foreground": "#E07A5F"
      }
    },
    {
      "scope": ["markup.heading"],
      "settings": {
        "foreground": "#9B7EDE",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.bold"],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.italic"],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["markup.list"],
      "settings": {
        "foreground": "#E07A5F"
      }
    },
    {
      "scope": ["markup.link"],
      "settings": {
        "foreground": "#7EB5D6",
        "fontStyle": "underline"
      }
    },
    {
      "scope": ["markup.quote"],
      "settings": {
        "foreground": "#A0A0A0",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["markup.raw"],
      "settings": {
        "foreground": "#81B29A",
        "background": "#F0EFEA"
      }
    },
    {
      "scope": ["storage.type.function", "keyword.declaration.function"],
      "settings": {
        "foreground": "#9B7EDE"
      }
    },
    {
      "scope": ["parameter", "variable.parameter"],
      "settings": {
        "foreground": "#D97706"
      }
    },
    {
      "scope": ["property", "variable.object.property"],
      "settings": {
        "foreground": "#4338CA"
      }
    },
    {
      "scope": ["support.constant"],
      "settings": {
        "foreground": "#E09F3E"
      }
    },
    {
      "scope": ["keyword.control.import", "keyword.control.from", "keyword.control.export"],
      "settings": {
        "foreground": "#9B7EDE"
      }
    },
    {
      "scope": ["entity.name.module", "string.quoted.source"],
      "settings": {
        "foreground": "#81B29A"
      }
    },
    {
      "scope": ["keyword.control.conditional", "keyword.control.loop"],
      "settings": {
        "foreground": "#9B7EDE"
      }
    },
    {
      "scope": ["keyword.control.return", "keyword.control.yield"],
      "settings": {
        "foreground": "#9B7EDE"
      }
    },
    {
      "scope": ["keyword.control.exception"],
      "settings": {
        "foreground": "#E07A5F"
      }
    },
    {
      "scope": ["punctuation.definition.tag", "punctuation.definition.string"],
      "settings": {
        "foreground": "#A0A0A0"
      }
    },
    {
      "scope": ["comment.block.documentation"],
      "settings": {
        "foreground": "#7EB5D6"
      }
    },
    {
      "scope": ["source.js", "source.ts", "source.tsx"],
      "settings": {
        "foreground": "#2D3436"
      }
    },
    {
      "scope": ["support.variable.property"],
      "settings": {
        "foreground": "#7EB5D6"
      }
    },
    {
      "scope": ["meta.decorator"],
      "settings": {
        "foreground": "#81B29A",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["template.expression"],
      "settings": {
        "foreground": "#E09F3E"
      }
    }
  ]
}
