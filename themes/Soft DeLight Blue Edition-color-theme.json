  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#6B7280"
      }
    },
    {
      "scope": ["keyword", "storage.type", "storage.modifier"],
      "settings": {
        "foreground": "#A78BFA"
      }
    },
    {
      "scope": ["string", "string.quoted", "string.template"],
      "settings": {
        "foreground": "#818CF8"
      }
    },
    {
      "scope": ["constant.numeric", "constant.language"],
      "settings": {
        "foreground": "#FBBF24"
      }
    },
    {
      "scope": ["entity.name.function", "support.function"],
      "settings": {
        "foreground": "#7DD3FC"
      }
    },
    {
      "scope": ["entity.name.type", "support.type"],
      "settings": {
        "foreground": "#6EE7B7"
      }
    },
    {
      "scope": ["variable", "identifier"],
      "settings": {
        "foreground": "#E8E8E8"
      }
    },
    {
      "scope": ["entity.name.class", "support.class"],
      "settings": {
        "foreground": "#6EE7B7"
      }
    },
    {
      "scope": ["punctuation", "meta.brace", "meta.delimiter"],
      "settings": {
        "foreground": "#9CA3AF"
      }
    },
    {
      "scope": ["operator", "keyword.operator"],
      "settings": {
        "foreground": "#F472B6"
      }
    },
    {
      "scope": ["tag", "entity.name.tag"],
      "settings": {
        "foreground": "#7DD3FC"
      }
    },
    {
      "scope": ["attribute", "entity.other.attribute-name"],
      "settings": {
        "foreground": "#FCD34D"
      }
    },
    {
      "scope": ["invalid", "error"],
      "settings": {
        "foreground": "#F97316"
      }
    },
    {
      "scope": ["markup.heading"],
      "settings": {
        "foreground": "#A78BFA",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.bold"],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.italic"],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["markup.list"],
      "settings": {
        "foreground": "#F97316"
      }
    },
    {
      "scope": ["markup.link"],
      "settings": {
        "foreground": "#7DD3FC",
        "fontStyle": "underline"
      }
    },
    {
      "scope": ["markup.quote"],
      "settings": {
        "foreground": "#6B7280",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["markup.raw"],
      "settings": {
        "foreground": "#6EE7B7",
        "background": "#252541"
      }
    },
    {
      "scope": ["storage.type.function", "keyword.declaration.function"],
      "settings": {
        "foreground": "#A78BFA"
      }
    },
    {
      "scope": ["parameter", "variable.parameter"],
      "settings": {
        "foreground": "#FCD34D"
      }
    },
    {
      "scope": ["property", "variable.object.property"],
      "settings": {
        "foreground": "#A5B4FC"
      }
    },
    {
      "scope": ["support.constant"],
      "settings": {
        "foreground": "#FCD34D"
      }
    },
    {
      "scope": ["keyword.control.import", "keyword.control.from", "keyword.control.export"],
      "settings": {
        "foreground": "#A78BFA"
      }
    },
    {
      "scope": ["entity.name.module", "string.quoted.source"],
      "settings": {
        "foreground": "#6EE7B7"
      }
    },
    {
      "scope": ["keyword.control.conditional", "keyword.control.loop"],
      "settings": {
        "foreground": "#A78BFA"
      }
    },
    {
      "scope": ["keyword.control.return", "keyword.control.yield"],
      "settings": {
        "foreground": "#A78BFA"
      }
    },
    {
      "scope": ["keyword.control.exception"],
      "settings": {
        "foreground": "#F97316"
      }
    },
    {
      "scope": ["punctuation.definition.tag", "punctuation.definition.string"],
      "settings": {
        "foreground": "#6B7280"
      }
    },
    {
      "scope": ["comment.block.documentation"],
      "settings": {
        "foreground": "#60A5FA"
      }
    },
    {
      "scope": ["source.js", "source.ts", "source.tsx"],
      "settings": {
        "foreground": "#E8E8E8"
      }
    },
    {
      "scope": ["support.variable.property"],
      "settings": {
        "foreground": "#7DD3FC"
      }
    },
    {
      "scope": ["meta.decorator"],
      "settings": {
        "foreground": "#6EE7B7",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["template.expression"],
      "settings": {
        "foreground": "#FCD34D"
      }
    }
  ]
}
